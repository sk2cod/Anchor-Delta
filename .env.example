# Copy to .env and fill in real values. Never commit .env.

ANTHROPIC_API_KEY=
TAVILY_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
GEMINI_API_KEY=

# Separate billing/key for the carousel engine's Sonnet/Haiku calls —
# not the same key as ANTHROPIC_API_KEY above.
CAROUSEL_ANTHROPIC_API_KEY=

# Carousel "Approve & Sync" export destination (Decision #52). Point this at
# a Google Drive / iCloud synced folder so approving a carousel writes its
# bundle straight to a per-carousel subfolder there (auto-created if
# missing) — no manual copy-to-Drive step. Leave empty to fall back to the
# local outputs/bundles/ folder instead. Not used at all when the Google
# Drive OAuth vars below are set (Stage 3 — INFRA_DECISIONS.md #02).
CAROUSEL_SYNC_DIR=G:\My Drive\Anchor & Delta\Outbox

# Google Drive upload for Approve & Sync (Stage 3 — INFRA_DECISIONS.md #02).
# All three optional — leave unset to keep the CAROUSEL_SYNC_DIR/local
# outputs/bundles/ behaviour above exactly as it works today. Run
# scripts/get_drive_refresh_token.py once to obtain the client ID/secret
# (from a Google Cloud OAuth "Desktop app" credential) and refresh token.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Optional — Drive folder ID to upload into. Leave unset on first run: the
# app creates a folder named "Anchor & Delta - Railway" and logs its ID so
# you can save it here for future runs (avoids creating a new folder every
# time).
GOOGLE_DRIVE_FOLDER_ID=

# Optional — password gate for a public Railway deployment (Stage 4).
# Leave unset for local dev: the app runs with no gate at all, unchanged
# from before this existed.
APP_PASSWORD=
